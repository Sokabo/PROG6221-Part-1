<Window x:Class="MegaMind.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MegaMind — Cybersecurity Companion"
        Height="700" Width="950"
        MinHeight="550" MinWidth="750"
        Background="#0A0E1A"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas">

    <Window.Resources>
        <!-- Reusable colours -->
        <SolidColorBrush x:Key="AccentCyan"   Color="#00E5FF"/>
        <SolidColorBrush x:Key="AccentMagenta" Color="#FF00C8"/>
        <SolidColorBrush x:Key="PanelDark"    Color="White"/>
        <SolidColorBrush x:Key="PanelMid"     Color="#111929"/>
        <SolidColorBrush x:Key="BorderGlow"   Color="#1C2E4A"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E0F0FF"/>
        <SolidColorBrush x:Key="TextDim"      Color="#4A6080"/>

        <!-- Send button style -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="#001F3F"/>
            <Setter Property="Foreground"   Value="#00E5FF"/>
            <Setter Property="BorderBrush"  Value="#00E5FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Padding"      Value="20,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#003366"/>
                                <Setter Property="BorderBrush" Value="#80FFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#00E5FF"/>
                                <Setter Property="Foreground" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input TextBox style -->
        <Style x:Key="InputBoxStyle" TargetType="TextBox">
            <Setter Property="Background"     Value="#060D1A"/>
            <Setter Property="Foreground"     Value="#E0F0FF"/>
            <Setter Property="CaretBrush"     Value="#00E5FF"/>
            <Setter Property="BorderBrush"    Value="#1C3A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"     Value="Consolas"/>
            <Setter Property="FontSize"       Value="14"/>
            <Setter Property="Padding"        Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#00E5FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Row 0: Header / ASCII art banner -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Chat history -->
            <RowDefinition Height="*"/>
            <!-- Row 2: Status bar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Input row -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ROW 0 — Header                                              -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#FFC8B046"
                BorderBrush="#1C2E4A"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel>
                <!-- ASCII art (monospaced, small) -->
                <TextBlock x:Name="AsciiArtBlock"
                           FontFamily="Consolas"
                           FontSize="7"
                           Foreground="#FF00C8"
                           TextWrapping="NoWrap"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"
                           Text=""/>

                <!-- Title bar row -->
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Blinking dot indicator -->
                        <Ellipse x:Name="StatusDot" Width="10" Height="10"
                                 Fill="#00FF80" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="1" To="0.2" Duration="0:0:1"
                                                             AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="MEGAMIND" Foreground="#00E5FF"
                                   FontSize="22" FontWeight="Bold" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="ClockBlock"
                               DockPanel.Dock="Right"
                               Foreground="#2A4060"
                               FontSize="11" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ROW 1 — Chat history                                        -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1"
                      Background="#FFC8B046"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,12">
            <StackPanel x:Name="ChatPanel" Margin="0,0,4,0"/>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ROW 2 — Status / hint bar                                   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#FFC8B046"
                BorderBrush="#1C2E4A"
                BorderThickness="0,1,0,0"
                Padding="16,5">
            <TextBlock x:Name="HintBlock"
                       Foreground="Black"
                       FontSize="11"
                       FontFamily="Consolas"
                       Text="Type a message and press Enter or click Send  •  Try: 'phishing', 'passwords', 'malware', 'tell me more'"/>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ROW 3 — Input row                                           -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="#FFB8B8B1"
                BorderBrush="#1C3A5A"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputBox"
                         Grid.Column="0"
                         Style="{StaticResource InputBoxStyle}"
                         Height="42"
                         KeyDown="UserInputBox_KeyDown"
                         GotFocus="UserInputBox_GotFocus"
                         LostFocus="UserInputBox_LostFocus"
                         Tag="Type your message here…" Foreground="Black" Background="#FF9C9EA1"/>

                <!-- Placeholder text layer (shown until user types) -->
                <TextBlock x:Name="PlaceholderText"
                           Grid.Column="0"
                           Text="Type your message here…"
                           Foreground="#FFEDEEF0"
                           FontFamily="Consolas"
                           FontSize="14"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="SEND ▶"
                        Height="42"
                        Style="{StaticResource SendButtonStyle}"
                        Click="SendButton_Click" Background="#FF060606" Grid.ColumnSpan="2" Margin="10,0,-7,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
